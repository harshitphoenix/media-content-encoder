# ─────────────────────────────────────────────
# Media Content Encoder — Environment Config
# Copy to .env and fill in real values.
# NEVER commit the .env file.
# ─────────────────────────────────────────────

# ── Node Environment ──────────────────────────
NODE_ENV=development

# ── API Server ────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0

# ── PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql://mce:mce_dev_password@localhost:5432/mce_dev

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 / MinIO Object Storage ─────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=mce_access_key
STORAGE_SECRET_ACCESS_KEY=mce_secret_key_change_me_in_prod
STORAGE_BUCKET_ORIGINALS=mce-originals
STORAGE_BUCKET_VARIANTS=mce-variants
STORAGE_REGION=us-east-1
# Set to true for MinIO/self-hosted; false for AWS S3
STORAGE_FORCE_PATH_STYLE=true

# ── CDN ───────────────────────────────────────
# Base URL through which processed assets are served
CDN_BASE_URL=http://localhost:9000/mce-variants
# Signed URL expiry (seconds); default 3600 = 1 hour
CDN_URL_TTL_SECONDS=3600

# ── File Limits ───────────────────────────────
# Maximum file sizes in bytes
MAX_IMAGE_SIZE_BYTES=104857600       # 100 MB
MAX_VIDEO_SIZE_BYTES=5368709120      # 5 GB
# Maximum image dimensions
MAX_IMAGE_WIDTH=7680
MAX_IMAGE_HEIGHT=4320
# Maximum video duration in seconds
MAX_VIDEO_DURATION_SECONDS=7200      # 2 hours

# ── Processing ────────────────────────────────
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_BASE_MS=5000
JOB_BACKOFF_TYPE=exponential

# ── Processing Tools ──────────────────────────
# Path to ffprobe binary (installed as part of FFmpeg)
# macOS: brew install ffmpeg  |  Ubuntu: apt install ffmpeg
FFPROBE_PATH=ffprobe

# ── Auth (JWT) ────────────────────────────────
# Must be at least 32 characters; generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRY=7d

# ── Log Level ─────────────────────────────────
LOG_LEVEL=info
