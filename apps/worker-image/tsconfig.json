{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "paths": {
      "@mce/shared": ["../../packages/shared/src/index.ts"],
      "@mce/db": ["../../packages/db/src/index.ts"],
      "@mce/storage": ["../../packages/storage/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/db" },
    { "path": "../../packages/storage" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
