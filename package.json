{
  "name": "media-content-encoder",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/**' build && pnpm -r --filter='./apps/**' build",
    "dev:api": "pnpm --filter @mce/api dev",
    "dev:worker-image": "pnpm --filter @mce/worker-image dev",
    "dev:worker-video": "pnpm --filter @mce/worker-video dev",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @mce/db db:generate",
    "db:migrate": "pnpm --filter @mce/db db:migrate",
    "db:studio": "pnpm --filter @mce/db db:studio",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:reset": "docker compose -f infra/docker-compose.yml down -v && docker compose -f infra/docker-compose.yml up -d",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
